{
  "name": "@kornorg/design-system",
  "version": "0.2.0",
  "description": "Modern Neutral — a token-driven React component library (Tailwind CSS v4), with a Spartan (Michigan State green) theme.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kornsour/design-system.git"
  },
  "homepage": "https://github.com/kornsour/design-system#readme",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/components/ui/index.js",
  "types": "./dist/components/ui/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/ui/index.d.ts",
      "import": "./dist/components/ui/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./theme-toggle": {
      "types": "./dist/components/theme-toggle.d.ts",
      "import": "./dist/components/theme-toggle.js"
    },
    "./palette-toggle": {
      "types": "./dist/components/palette-toggle.d.ts",
      "import": "./dist/components/palette-toggle.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "build:package": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && cp src/app/globals.css dist/styles.css",
    "prepublishOnly": "pnpm build:package",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-safe-action": "^8.5.4",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsc-alias": "^1.9.0",
    "typescript": "^6",
    "vitest": "^4.1.9"
  }
}
