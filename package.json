{
  "name": "@kornorg/design-system",
  "version": "0.4.0",
  "description": "Modern Neutral — a React + Tailwind CSS design system (components, tokens, Geist fonts).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kornsour/design-system.git"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "tailwindcss",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "engines": {
    "node": ">=24"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.mjs"
    },
    "./styles.css": "./dist/styles.css",
    "./themes/*": "./dist/themes/*"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "tsup && node scripts/postbuild.mjs && pnpm run build:css",
    "build:css": "node scripts/build-css.mjs",
    "build:showcase": "next build",
    "prepack": "pnpm run build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "geist": "^1.7.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.16",
      "esbuild@>=0.27.3 <0.28.1": "^0.28.1",
      "postcss@<8.5.10": "^8.5.10"
    }
  }
}
